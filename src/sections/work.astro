---
import work from '../data/work.json';
import WorkCard from '../components/WorkCard.astro';
---

<section id="work" class="w-full flex flex-col self-center items-center gap-6">
  <h2 class="text-5xl md:text-6xl text-primary text-center">Work</h2>
  <p class="text-xl md:text-2xl text-foreground/60 mb-4 md:mb-8 text-center">
    Where I've been and what I took from it. For the full timeline, see my <a href="/CV_DominikJessen.pdf" target="_blank" class="text-primary font-signika">CV</a>.
  </p>
  {work.map((entry) => (
    <WorkCard entry={entry} />
  ))}
</section>
