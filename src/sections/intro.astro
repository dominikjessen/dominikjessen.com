---
import AchievementCards from '../components/AchievementCards';
---

<section id="intro" class="grid grid-cols-1 lg:grid-cols-2 gap-8 justify-end items-center pt-12 mt-24">
  <div class="flex flex-col gap-6">
    <span class="text-7xl animate-wave origin-[70%_70%] w-fit intersect-target">👋🏻</span>
    <h1 class="font-bold text-7xl mb-4 text-primary intersect-target">Hi, I'm Dominik.</h1>
    <p class="text-foreground_lighter text-2xl leading-relaxed">
      I'm a <span class="text-primary font-signika">software engineer who used to be a PM</span>. I've owned roadmaps, written strategy docs, and led 10+ person teams across engineering and research. Then I went back to engineering - because I wanted to be the one actually building.
    </p>
    <p class="text-foreground_lighter text-2xl leading-relaxed">
      Currently, I'm a senior fullstack engineer at <a href="https://vespertool.com/" target="_blank" class="text-primary font-signika">Vesper</a> helping professionals
      navigate commodities markets.
    </p>
  </div>
  <AchievementCards client:load className="flex flex-col mx-auto"  />
</section>
